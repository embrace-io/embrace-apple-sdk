#!/usr/bin/env bash
set -Eeuo pipefail

get_best_sim() {
  local container="$1"
  local scheme="$2"
  local name="$3"
  local os="$4"
  local ver="$5"

  get_sim "$container" "$scheme" "$name" "$os" "$ver" 1 \
    | jq -r '.[0].id // empty'
}

# Usage:
#   param 1: .xcworkspace or .xcodeproj
#   param 2: scheme
#   param 3: device name (e.g. "iPhone 14 Pro", "~iPhone", or "" for any)
#   param 4: OS platform (e.g. "iOS", "~iOS", or "" for any)
#   param 5: OS version (e.g. "17.0", "~17", or "" for any)

get_sim() {
  local container="$1"   # .xcworkspace or .xcodeproj
  local scheme="$2"
  local name="$3"
  local os="$4"
  local ver="$5"
  local limit="${6:-1}"   # default: 1

  # Strip leading ~ and mark fuzzy flags
  local nameFuzzy=0 osFuzzy=0 verFuzzy=0
  if [[ "$name" == ~* ]]; then name="${name:1}"; nameFuzzy=1; fi
  if [[ "$os"   == ~* ]]; then os="${os:1}";   osFuzzy=1;   fi
  if [[ "$ver"  == ~* ]]; then ver="${ver:1}"; verFuzzy=1;  fi

  # Figure out which flag to use for xcodebuild
  local flag
  case "$container" in
    *.xcworkspace) flag="-workspace" ;;
    *.xcodeproj)   flag="-project"   ;;
    *) echo "Unknown container type: $container" >&2; return 2 ;;
  esac

  # Run xcodebuild -showdestinations and convert to JSON
  local json
  json="$(
    xcodebuild "$flag" "$container" -scheme "$scheme" -showdestinations 2>/dev/null \
    | sed -n 's/.*platform:\([^,}]*\).*id:\([^,}]*\).*OS:\([^,}]*\).*name:\([^}]*\).*/{"platform":"\1","id":"\2","os":"\3","name":"\4"}/p' \
    | jq -s .
  )"

  jq -r \
    --arg NAME "$name" \
    --arg OS "$os" \
    --arg VER "$ver" \
    --argjson NAME_FUZZY "$nameFuzzy" \
    --argjson OS_FUZZY "$osFuzzy" \
    --argjson VER_FUZZY "$verFuzzy" \
    --argjson LIMIT "$limit" '
      def down: ascii_downcase;

      [ .[] 
        | select(.name != "Any iOS Simulator Device") # skip placeholder
        | select(
            ($NAME == "") or
            ($NAME_FUZZY == 0 and ((.name | down) == ($NAME | down))) or
            ($NAME_FUZZY == 1 and ((.name | down) | contains($NAME | down)))
          )
        | select(
            ($OS == "") or
            ($OS_FUZZY == 0 and ((.platform | down) == ($OS | down))) or
            ($OS_FUZZY == 1 and ((.platform | down) | contains($OS | down)))
          )
        | select(
            ($VER == "") or
            ($VER_FUZZY == 0 and (.os == $VER)) or
            ($VER_FUZZY == 1 and ((.os | startswith($VER)) or (.os | contains($VER))))
          )
        | .ver_nums = ((.os // "0") | split(".") | map(tonumber? // 0))
      ]
      | sort_by(.ver_nums) | reverse
      | .[:$LIMIT]
      | map(del(.ver_nums))
    ' <<<"$json"
}
