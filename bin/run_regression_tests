#!/bin/bash
set -Eeuo pipefail

$EMB_BIN_HOME/platform
source $EMB_BIN_HOME/destinations

echo "EmbraceIO"
get_best_id ".swiftpm/xcode/package.xcworkspace" "EmbraceIO-Package" "~iPhone" "iOS Simulator" "~"

echo "Benchmarks"
get_best_id "Examples/Benchmarks/Benchmarks.xcworkspace" "Benchmarks" "~iPhone" "iOS Simulator" "~"

$EMB_BIN_HOME/benchmarks >benchmarks.json
$EMB_BIN_HOME/perf >perf.json
          
cat perf.json
cat benchmarks.json

jq -n \
    --slurpfile a perf.json \
    --slurpfile b benchmarks.json \
    '$a[0] + $b[0]' \
    > combined.json

cat combined.json

    echo "out<<EOF" >> "$GITHUB_OUTPUT"
    cat combined.json >> "$GITHUB_OUTPUT"
    echo "EOF" >> "$GITHUB_OUTPUT"